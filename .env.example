# TCMB EVDS API Key
# Required: Your API key for accessing the TCMB EVDS service
TCMB_API_KEY=your_tcmb_api_key_here

# Proxy API Keys
# Required: Comma-separated list of valid API keys for clients to access this proxy
# Generate secure random keys for production use
# Example: PROXY_API_KEYS=key1,key2,key3
PROXY_API_KEYS=your_proxy_api_key_here

# Apprise API URL (e.g., http://localhost:8000 or http://apprise:8000 if inside docker network)
APPRISE_API_URL=http://localhost:8000

# Default Apprise Notification connection URL (e.g., tgram://bottoken/chatid)
APPRISE_NOTIFICATION_URL=your_apprise_notification_url_here

